{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "volunteer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A volunteer's registration.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "etapa1": { "type": "object" },
        "etapa2": { "type": "array" },
        "etapa3": { "type": "object" },
        "etapa4": { "type": "array" },
        "escala": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "createdAt", "updatedAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global settings for the event.",
      "type": "object",
      "properties": {
        "maxSlots": { "type": "object" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "registrations/{userId}": {
      "schema": { "$ref": "#/entities/Registration" },
      "description": "Registrations collection, ID is userId"
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global settings"
    }
  }
}
